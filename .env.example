# GenLayer Studionet RPC endpoint
# NOTE: this file is documentation only - frontend/index.html is a static
# file with no build step, so these values are NOT read from .env at
# runtime. Instead, copy them directly into the CONTRACT_ADDRESS and
# RPC_URL constants near the top of the <script> block in index.html
# before deploying to Vercel.
GENLAYER_RPC_URL=https://studio.genlayer.com/api

# Deployed contract address (fill in after deploying
# contract/governance_simulator.py). Re-check this after any redeploy -
# an old address will point at a stale contract instance with a
# different state history.
CONTRACT_ADDRESS=
